# ─────────────────────────────────────────────────────────────
# Sole Digital Service — variables de entorno
# Copia este archivo a `.env.local` y rellena los valores.
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (usada en metadatos SEO, sitemap y robots).
NEXT_PUBLIC_SITE_URL=https://soledigitalservice.com

# ─── Formulario de contacto (Nodemailer / SMTP) ───
# Si configuras estas variables, el formulario enviará un correo real.
# Si las dejas vacías, los mensajes se guardan en data/messages.json (modo respaldo).
#
# Ejemplos de proveedores SMTP gratuitos/autónomos:
#   • Gmail  -> host: smtp.gmail.com   port: 587  (usa una "App Password", no tu clave normal)
#   • Zoho   -> host: smtp.zoho.com    port: 465
#   • Brevo  -> host: smtp-relay.brevo.com  port: 587
#   • Tu propio servidor de correo / Postfix.

SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=tu-usuario@tu-dominio.com
SMTP_PASS=tu-contraseña-o-app-password

# Dirección que RECIBE los mensajes del formulario.
# Si se omite, se usa el email definido en lib/site.ts.
CONTACT_EMAIL=hello@soledigitalservice.com
